    "fonts": {
      "allowed": [
        "Arial",
        "Font Awesome 5 Free",
        "Inter",
        "Lato",
        "Montserrat",
        "Nunito",
        "Open Sans",
        "Poppins",
        "Racing Sans One",
        "Red Hat Display",
        "Roboto",
        "Segoe UI"
      ],
      "banned": [
        "Poppins",
        "Inter",
        "Arial",
        "Helvetica",
        "Open Sans",
        "Lato",
        "Nunito"
      ]
    },
    "typography": {
      "headingFont": "Roboto",
      "bodyFont": "Roboto",
      "ctaFont": "Red Hat Display",
      "weights": [
        300,
        400,
        500,
        600,
        700
      ]
    }
  },
  "components": {
    "package": "@dock/console-uikit-vue",
    "styleImport": "@dock/console-uikit-vue/style.css",
    "preferImport": [
      "DockButton",
      "DockInput",
      "DockSelect",
      "DockStepper",
      "DockTypography",
      "DockCard",
      "DockModal",
      "DockDialog",
      "DockToast",
      "DockAlert",
      "DockBadge",
      "DockTag",
      "DockAvatar",
      "DockTooltip",
      "DockTabs",
      "DockTab",
      "DockBreadcrumb",
      "DockSidebar",
      "DockNavbar",
      "DockTable",
      "DockPagination",
      "DockCheckbox",
      "DockRadio",
      "DockSwitch",
      "DockTextarea",
      "DockDatePicker",
      "DockDropdown",
      "DockAccordion",
      "DockSkeleton",
      "DockSpinner",
      "DockProgressBar",
      "DockDivider",
      "DockIcon",
      "DockLink",
      "DockFormField",
      "DockEmptyState"
    ],
    "componentMap": {
      "<button>": "DockButton",
      "<input>": "DockInput",
      "<select>": "DockSelect",
      "<textarea>": "DockTextarea",
      "<table>": "DockTable",
      "<dialog>": "DockDialog",
      "<a> (styled as button)": "DockButton (as='a')",
      "<nav> tabs": "DockTabs",
      "<nav> breadcrumb": "DockBreadcrumb"
    },
    "exceptions": [
      "<input type=\"range\"> — usar nativo estilizado (slider)",
      "<input type=\"date\"> — usar nativo (acessibilidade)",
      "<input> com máscara custom — pode usar DockInput ou nativo com composable"
    ]
  },
  "validation": {
    "scripts": {
      "design": "npm run validate:design",
      "a11y": "npm run test:a11y",
      "unit": "npm run test",
      "lint": "npm run lint:gate",
      "pipeline": "npm run validate"
    },
    "contrastMinimum": {
      "normalText": 4.5,
      "largeText": 3,
      "uiComponents": 3
    }
  },
  "figma": {
    "fileId": "ENnwAECm4eFvT0pLXRVQXd",
    "designSystemDoc": "./DESIGN_SYSTEM.md",
    "nodeDataFile": "./figma-node-data.json",
    "owner": "design-system@dock.com.br",
    "canonicalPages": [
      "Jornada Mobile Completa"
    ],
    "approvedNodes": [],
    "lastSyncedAt": null,
    "syncStrategy": {
      "ci": {
        "schedule": "daily",
        "branch": "chore/figma-sync",
        "autoCreatePR": true,
        "serviceAccount": "dock-ci-figma@dock.com.br"
      },
      "local": {
        "envFile": ".env.local",
        "outputFiles": [
          "dock-ds.config.json",
          "figma-node-data.json"
        ]
      }
    }
  },
  "rules": {
    "slider": {
      "thumbColor": "#ffffff",
      "thumbSize": "24x24",
      "thumbBorderRadius": "0",
      "trackColor": "#b9b9b9",
      "trackHeight": "10px",
      "buttonOrder": "minus-left-plus-right"
    },
    "backgrounds": {
      "fullWidth": true,
      "noLateralMargins": true
    },
    "mobile": {
      "minWidth": 375,
      "maxWidth": 414,
      "containerClass": "w-full max-w-[414px] mx-auto"
    },
    "responsiveness": {
      "approach": "mobile-first",
      "breakpoints": {
        "sm": "375px",
        "md": "768px",
        "lg": "1024px",
        "xl": "1280px",
        "2xl": "1536px"
      },
      "touchTarget": {
        "minimum": "24x24",
        "recommended": "44x44"
      }
    },
    "performance": {
      "budgets": {
        "js_gzip_kb": 80,
        "css_gzip_kb": 20,
        "total_gzip_kb": 100,
        "image_max_kb": 200
      },
      "webVitals": {
        "LCP": "2.5s",
        "INP": "200ms",
        "CLS": "0.1"
      }
    }
  }
}
